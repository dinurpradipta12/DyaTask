{
  "name": "dyatask-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "node scripts/generate-deploy-version.cjs && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder --config.extraMetadata.version=$(node scripts/print-app-version.cjs)",
    "electron:pack": "npm run build && electron-builder --dir --config.extraMetadata.version=$(node scripts/print-app-version.cjs)",
    "electron:dist:mac": "npm run build && electron-builder --mac --publish never --config.extraMetadata.version=$(node scripts/print-app-version.cjs)",
    "electron:publish:mac": "npm run build && electron-builder --mac --publish always --config.extraMetadata.version=$(node scripts/print-app-version.cjs)"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.dyatask.manager",
    "productName": "Dyatask Manager - Superapp for Freelancer",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/minilogo-dyatask.png",
        "to": "minilogo-dyatask.png"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dinurpradipta12",
        "repo": "DyaTask"
      }
    ],
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
